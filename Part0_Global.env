#
# 文件名字: Part0_Global.env
# 文件说明: 全局变量配置
# 使用说明: 按需修改变量值，自动加载生效
#
# Copyright (c) 2026 ChenOSWrt
#

# 固件前缀名称
SOURCE_NAME=immortalwrt
# OpenWrt源码仓库地址
REPO_URL=https://github.com/immortalwrt/immortalwrt
# 源码分支
REPO_BRANCH=openwrt-24.10
# 更新日志
RELEASE_NOTES=release.txt

# 自定义前置脚本1
PART1_FEEDS=Part1_Feeds.sh
# 自定义后置脚本2
PART2_CUSTOM=Part2_Custom.sh

# 是否上传完整编译bin目录
UPLOAD_BIN_DIR=false
# 是否上传编译好的固件
UPLOAD_FIRMWARE=false
# 是否发布到Releases
UPLOAD_RELEASE=true

# 是否启用编译缓存（Ccache）
#USE_CCACHE=false
# 编译缓存文件存放目录
#CCACHE_DIR=/home/runner/.ccache

# 设置时区 (默认-上海)
TZ=Asia/Shanghai

# 是否启用编译缓存（Ccache）
USE_CCACHE=true

# 编译缓存文件存放目录
CCACHE_DIR=${{ github.workspace }}/.ccache

# 严格控制缓存大小：ccache 8GB + dl 1GB = 9GB 总占用
# 预留 1GB 给 GitHub 缓存系统的 overhead
CCACHE_MAXSIZE=8G
CCACHE_COMPRESS=true
# 提高压缩级别到 9，比默认 6 多压缩 30%，只增加少量 CPU 时间
CCACHE_COMPRESSLEVEL=9
CCACHE_DIRECT=true
CCACHE_DEPEND=true
# 禁用路径哈希，彻底解决绝对路径缓存失效
CCACHE_NOHASHDIR=true
# 启用文件修改时间检查，避免不必要的重新编译
CCACHE_FILECLONE=true

# 下载目录缓存（严格控制在 1GB 以内）
DL_DIR=${{ github.workspace }}/dl
